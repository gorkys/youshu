<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.YouShu" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.YouShu.Launcher" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_empty</item>
        <item name="windowSplashScreenBackground">#FFFFFBF4</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.YouShu</item>
    </style>
</resources>
